{
  "name": "tup/thesis-archive-api",
  "description": "TUP Manila Thesis Archive Management System API",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0",
    "ably/ably-php": "^1.1",
    "guzzlehttp/guzzle": "^7.8"
  },
  "require-dev": {
    "laravel/pint": "^1.14",
    "laravel/sail": "^1.28",
    "mockery/mockery": "^1.6",
    "phpunit/phpunit": "^11.0"
  },
  "require": {
  "php": "^8.2",
  "laravel/framework": "^11.0",
  "laravel/sanctum": "^4.0",
  "ably/ably-php": "^1.1",
  "guzzlehttp/guzzle": "^7.8",
  "resend/resend-php": "^0.10.0"
},
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-create-project-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php artisan key:generate --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin-laravel": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
